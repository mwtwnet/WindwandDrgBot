{
  "name": "disbase-v4",
  "version": "1.0.1",
  "packageManager": "pnpm@11.8.0",
  "description": "",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "typecheck": "prisma generate && tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "dev": "tsx watch --exclude config.json index.ts",
    "zip": "pnpm build && tsx .script/zip.ts",
    "upload": "tsx .script/upload.ts",
    "dp": "tsx .script/deploy.ts",
    "newcmd": "tsx .script/newCmd.ts",
    "newtri": "tsx .script/newTrigger.ts"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "archiver": "^7.0.1",
    "console-log-colors": "^0.5.0",
    "discord.js": "^14.26.5",
    "dotenv": "^17.2.3",
    "enquirer": "^2.4.1",
    "prisma": "^7.8.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/archiver": "^8.0.0",
    "@types/node": "^24.13.3",
    "tsc-alias": "^1.9.0",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3"
  }
}
